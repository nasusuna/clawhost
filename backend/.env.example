# ClawHost Backend — copy to .env and fill values

# App
APP_ENV=development
SECRET_KEY=your-secret-key-min-32-chars
API_HOST=0.0.0.0
API_PORT=8000
# LOG_LEVEL=INFO
# Production: comma-separated frontend origins (e.g. https://app.clawhost.com)
# CORS_ALLOWED_ORIGINS=

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/clawhost

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Redis (for queue)
REDIS_URL=redis://localhost:6379/0

# Provider: Contabo (OAuth2 from Customer Control Panel → API)
CONTABO_API_URL=https://api.contabo.com
CONTABO_CLIENT_ID=
CONTABO_CLIENT_SECRET=
CONTABO_API_USER=
CONTABO_API_PASSWORD=
# VULTR_API_KEY=
# DO_API_TOKEN=

# Cloudflare DNS
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLAWHOST_BASE_DOMAIN=customers.yourdomain.com

# OpenClaw on VPS (Docker image + app port for Nginx proxy)
OPENCLAW_DOCKER_IMAGE=fourplayers/openclaw:latest
OPENCLAW_APP_PORT=18789
# Optional: Gemini API key used for new instances when user has not set one (shared key; you pay usage)
# GEMINI_API_KEY=
# OpenRouter: create one API key per instance (Management API key from https://openrouter.ai/settings/management-keys)
# OPENROUTER_MANAGEMENT_API_KEY=
# OPENROUTER_KEY_LIMIT_USD=0
# OPENROUTER_KEY_LIMIT_RESET=monthly
# Admin: secret for X-Admin-Secret header (add/list Gemini key pool). If set, admin routes are enabled.
# ADMIN_SECRET=

# Automated Gemini key pool replenishment (create keys via GCP API Keys API, store in DB). Requires ARQ worker.
# GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # service account with API Keys Admin
# GEMINI_KEY_POOL_MIN_AVAILABLE=2
# GEMINI_KEY_POOL_REPLENISH_ENABLED=false

# One GCP project per subscription: create project, enable Generative Language API, link billing, create $15 budget, then create Gemini key.
# Requires GCP_ORGANIZATION_ID and GCP_BILLING_ACCOUNT_ID. Service account needs: Project Creator, Service Usage Admin, Billing User, Budget Admin, API Keys Admin.
# GCP_PROJECT_PER_SUBSCRIPTION_ENABLED=true
# GCP_ORGANIZATION_ID=123456789012
# GCP_BILLING_ACCOUNT_ID=01ABC2D-3EF4G5-6789HI
# GCP_BUDGET_AMOUNT_USD=15

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
